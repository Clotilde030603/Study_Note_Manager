# Study Note Manager docker-compose environment example

# Frontend
FRONTEND_PORT=8080
API_BASE_URL=/api

# Backend
BACKEND_PORT=5001
NODE_ENV=production
CORS_ORIGIN=http://localhost:8080
DB_HOST=mysql
DB_PORT=3306
DB_USER=study_user
DB_PASSWORD=study_password
DB_NAME=study_note_manager
DB_CONNECTION_LIMIT=10
DB_CHARSET=utf8mb4
DB_CONNECT_RETRIES=30
DB_CONNECT_RETRY_DELAY_MS=2000

# MySQL
MYSQL_PORT=3307
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=study_note_manager
MYSQL_USER=study_user
MYSQL_PASSWORD=study_password
